{
  "manifest_version": 3,
  "name": "HyperFetch",
  "version": "1.0.0",
  "description": "Accelerate large file downloads (>100MB) using parallel threads",
  "browser_specific_settings": {
    "gecko": {
      "id": "hyperfetch@hyperfetch.local",
      "strict_min_version": "121.0"
    }
  },
  "permissions": [
    "downloads",
    "storage",
    "notifications",
    "nativeMessaging",
    "cookies",
    "webRequest"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "16": "images/icon-16.png",
    "32": "images/icon-32.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  },
  "background": {
    "scripts": ["src/background.js"]
  },
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "HyperFetch",
    "default_icon": {
      "16": "images/icon-16.png",
      "32": "images/icon-32.png",
      "48": "images/icon-48.png",
      "128": "images/icon-128.png"
    }
  },
  "options_ui": {
    "page": "src/options.html",
    "open_in_tab": true
  }
}
