{
  "manifest_version": 3,
  "name": "HyperFetch",
  "version": "1.0.0",
  "description": "Accelerate large file downloads (>100MB) using parallel threads in Microsoft Edge",
  "key": "",
  "permissions": [
    "downloads",
    "storage",
    "notifications",
    "nativeMessaging",
    "cookies",
    "webRequest"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "16": "images/icon-16.png",
    "32": "images/icon-32.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "HyperFetch",
    "default_icon": {
      "16": "images/icon-16.png",
      "32": "images/icon-32.png",
      "48": "images/icon-48.png",
      "128": "images/icon-128.png"
    }
  },
  "options_page": "src/options.html"
}
